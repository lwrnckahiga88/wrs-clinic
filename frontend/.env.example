# Leave blank for plain local dev (uses Vite's proxy to localhost:4000).
# Set this once you're serving the built app / accessing via a Cloudflare
# tunnel, so /api calls know where the Gateway actually is:
#   VITE_API_BASE_URL=https://your-tunnel.trycloudflare.com
#
# Tunnel URLs rotate often — you usually don't need to touch this and
# rebuild. Instead, open the app > Modules tab > set "Gateway URL" there;
# it's stored in localStorage and overrides this at runtime.
VITE_API_BASE_URL=

# Only needed if Vite's dev server rejects your tunnel's Host header
# ("Blocked request. This host is not allowed"). Set to the exact
# hostname, e.g. your-tunnel.trycloudflare.com
VITE_DEV_ALLOWED_HOST=
